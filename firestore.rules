rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from an authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: does the authenticated user own the document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Campus Feed ──────────────────────────────────────────────────────────
    match /feed/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && resource.data.authorId == request.auth.uid;
      }
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && resource.data.authorId == request.auth.uid;
      }

      match /likes/{likeId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == likeId;
      }
    }

    // ── Projects ─────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;
    }

    // ── Marketplace ──────────────────────────────────────────────────────────
    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.sellerId == request.auth.uid;
    }

    // ── Team Finder Posts ────────────────────────────────────────────────────
    match /team_posts/{postId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.posterId == request.auth.uid;

      match /requests/{requestId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Resources / Knowledge Hub ────────────────────────────────────────────
    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /knowledge_hub/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Campus Updates ───────────────────────────────────────────────────────
    match /campus_updates/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);

      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Conversations (1:1 DMs) ───────────────────────────────────────────────
    match /conversations/{convId} {
      allow read, update: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
  }
}
